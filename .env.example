# Root environment reference for local development.
# Copy backend variables into backend/.env if you prefer package-local env files.
# Copy frontend variables into frontend/.env.local if you prefer package-local env files.

# Backend
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/ai-resume-analyzer-pro
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FRONTEND_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=
ADMIN_EMAIL=admin@example.com

# Frontend
NEXT_PUBLIC_API_URL=https://ai-resume-analyzer-fz8b.onrender.com/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
